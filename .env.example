# ExamBox configuration
# Copy this file to .env and adjust as needed. All values below are the defaults.

# --- Database ---
# Async SQLAlchemy connection string.
DATABASE_URL=sqlite+aiosqlite:///./data/exambox.db

# --- Paths ---
# Root for exams, materials, workspaces and submissions, as seen from inside the container.
DATA_PATH=/app/data

# Absolute path to this repository's data/ directory on the HOST machine.
# Only required for per-student container provisioning (see the Roadmap in README.md),
# because Docker bind mounts are resolved by the host daemon, not by the container.
# Examples:
#   Linux / macOS:  HOST_DATA_PATH=/home/you/Exam_Box/data
#   Windows:        HOST_DATA_PATH=C:/Users/you/Exam_Box/data
# HOST_DATA_PATH=

# --- Services ---
# Base URL of the JupyterLab instance handed to students. Use the host's LAN IP
# (e.g. http://192.168.1.100:8888) when serving students on other machines.
JUPYTER_URL=http://localhost:8888

# JupyterLab authentication token. Change this for any real deployment.
JUPYTER_TOKEN=exambox123

# Internal URL students' containers use to reach the exam manager.
EXAM_MANAGER_URL=http://exam-manager:8000
